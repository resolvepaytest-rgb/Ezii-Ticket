{
  "info": {
    "name": "EziiTicket Phase 3",
    "_postman_id": "e6b96d2e-420e-4c0f-b1f5-a9792d25f3f4",
    "description": "Phase 3 tests for SLA warning/breach, pause/resume and auto-close helpers.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "Create Ticket",
      "request": {
        "method": "POST",
        "header": [
          { "key": "Authorization", "value": "Bearer {{jwt_token}}", "type": "text" },
          { "key": "Content-Type", "value": "application/json", "type": "text" }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"product_id\": {{product_id}},\n  \"category_id\": {{category_id}},\n  \"subcategory_id\": {{subcategory_id}},\n  \"channel\": \"widget\",\n  \"priority\": \"P3\",\n  \"affected_users\": 8,\n  \"subject\": \"Phase3 SLA runtime verification\",\n  \"description\": \"This ticket validates warning, breach escalation, pause resume math, and auto-close scheduler behavior.\"\n}"
        },
        "url": { "raw": "{{baseUrl}}/tickets", "host": ["{{baseUrl}}"], "path": ["tickets"] }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('status is 201', function () { pm.response.to.have.status(201); });",
              "const json = pm.response.json();",
              "if (json && json.data) pm.collectionVariables.set('ticket_id', String(json.data.id));"
            ]
          }
        }
      ]
    },
    {
      "name": "Set Pending",
      "request": {
        "method": "POST",
        "header": [
          { "key": "Authorization", "value": "Bearer {{jwt_token}}", "type": "text" },
          { "key": "Content-Type", "value": "application/json", "type": "text" }
        ],
        "body": { "mode": "raw", "raw": "{\n  \"status\": \"pending\",\n  \"reason\": \"waiting_for_customer\"\n}" },
        "url": { "raw": "{{baseUrl}}/tickets/{{ticket_id}}/status", "host": ["{{baseUrl}}"], "path": ["tickets", "{{ticket_id}}", "status"] }
      }
    },
    {
      "name": "Set Open (resume)",
      "request": {
        "method": "POST",
        "header": [
          { "key": "Authorization", "value": "Bearer {{jwt_token}}", "type": "text" },
          { "key": "Content-Type", "value": "application/json", "type": "text" }
        ],
        "body": { "mode": "raw", "raw": "{\n  \"status\": \"open\",\n  \"reason\": \"customer_replied\"\n}" },
        "url": { "raw": "{{baseUrl}}/tickets/{{ticket_id}}/status", "host": ["{{baseUrl}}"], "path": ["tickets", "{{ticket_id}}", "status"] }
      }
    },
    {
      "name": "Set Resolved",
      "request": {
        "method": "POST",
        "header": [
          { "key": "Authorization", "value": "Bearer {{jwt_token}}", "type": "text" },
          { "key": "Content-Type", "value": "application/json", "type": "text" }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"status\": \"resolved\",\n  \"resolution_note\": \"Resolved after validating root cause, applying fix, retesting edge paths, and confirming expected behavior in production mirror.\",\n  \"reason\": \"phase3_resolve\"\n}"
        },
        "url": { "raw": "{{baseUrl}}/tickets/{{ticket_id}}/status", "host": ["{{baseUrl}}"], "path": ["tickets", "{{ticket_id}}", "status"] }
      }
    },
    {
      "name": "Reopen",
      "request": {
        "method": "POST",
        "header": [
          { "key": "Authorization", "value": "Bearer {{jwt_token}}", "type": "text" },
          { "key": "Content-Type", "value": "application/json", "type": "text" }
        ],
        "body": { "mode": "raw", "raw": "{\n  \"reason\": \"Issue reoccurred\"\n}" },
        "url": { "raw": "{{baseUrl}}/tickets/{{ticket_id}}/reopen", "host": ["{{baseUrl}}"], "path": ["tickets", "{{ticket_id}}", "reopen"] }
      }
    },
    {
      "name": "Escalate",
      "request": {
        "method": "POST",
        "header": [
          { "key": "Authorization", "value": "Bearer {{jwt_token}}", "type": "text" },
          { "key": "Content-Type", "value": "application/json", "type": "text" }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"target_team_id\": {{target_team_id}},\n  \"target_queue_id\": {{target_queue_id}},\n  \"handoff_note\": \"Escalating due to SLA risk and complexity\",\n  \"reason\": \"complexity\"\n}"
        },
        "url": { "raw": "{{baseUrl}}/tickets/{{ticket_id}}/escalate", "host": ["{{baseUrl}}"], "path": ["tickets", "{{ticket_id}}", "escalate"] }
      }
    },
    {
      "name": "Ticket Detail (events)",
      "request": {
        "method": "GET",
        "header": [
          { "key": "Authorization", "value": "Bearer {{jwt_token}}", "type": "text" }
        ],
        "url": { "raw": "{{baseUrl}}/tickets/{{ticket_id}}", "host": ["{{baseUrl}}"], "path": ["tickets", "{{ticket_id}}"] }
      }
    }
  ],
  "variable": [
    { "key": "baseUrl", "value": "http://localhost:5000" },
    { "key": "jwt_token", "value": "" },
    { "key": "product_id", "value": "1" },
    { "key": "category_id", "value": "86" },
    { "key": "subcategory_id", "value": "254" },
    { "key": "target_team_id", "value": "18" },
    { "key": "target_queue_id", "value": "15" },
    { "key": "ticket_id", "value": "" }
  ]
}

