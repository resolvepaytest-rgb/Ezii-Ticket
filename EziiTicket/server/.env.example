PORT=4000
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/ezii_ticket
JWT_SECRET=change-me
JWT_ISSUER=https://localhost:5003
JWT_AUDIENCE=https://localhost:5003

# Outbound notification email (optional; omit SMTP_HOST to skip sending — in-app events still run)
NOTIFICATION_EMAIL_ENABLED=1
TICKET_PORTAL_BASE_URL=http://localhost:5173
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=0
SMTP_USER=
SMTP_PASS=
SMTP_FROM=noreply@localhost

# External platform API (GET /organization/email-status/:orgId — no token) for routing outbound mail:
# when an org’s product flag is false, notifications go to NOTIFICATION_SANDBOX_EMAIL instead of the user.
# If this call fails or returns no usable data, ticket notification emails are not sent.
# EXTERNAL_API_URL=https://qa-api.example.com
# NOTIFICATION_SANDBOX_EMAIL=resolvepaytest@gmail.com

# --- Ticket background automation (SLA + auto-close) ---
# When TICKET_AUTOMATION_ENABLED=0, the server does not schedule runSlaTick / runAutoCloseTick.
# Default is on (omit or any value except "0").
# TICKET_AUTOMATION_ENABLED=0
#
# runSlaTick: resolution SLA ~75% warning events; resolution breach → status escalated (open/reopened tickets).
# SLA_TICK_SECONDS: poll interval in seconds (minimum 15s enforced in code).
# SLA_TICK_SECONDS=60
#
# runAutoCloseTick: tickets in "resolved" for 7+ calendar days → "closed".
# AUTO_CLOSE_TICK_SECONDS: poll interval in seconds (minimum 30s enforced in code).
# AUTO_CLOSE_TICK_SECONDS=300

